# ============================================================
# SoulSync AI — Environment Configuration Template
# Copy this file to .env and fill in your values
# ============================================================
#
# QUICK START:
# 1. Copy this file: cp .env.example .env
# 2. Get Groq API key: https://console.groq.com/keys
# 3. Set up MongoDB: https://www.mongodb.com/cloud/atlas (free tier available)
# 4. (Optional) Set up Redis for caching
#
# ============================================================

# ─── Groq API (Required) ────────────────────────────────────
# Get your free API key from https://console.groq.com/keys
# Used for: AI response generation (llama-3.3-70b-versatile model)
GROQ_API_KEY=your_groq_api_key_here

# ─── JWT Authentication ─────────────────────────────────────
# Secret key for signing JWT tokens - CHANGE THIS IN PRODUCTION!
# Generate a strong random string (at least 32 characters)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
# Token expiration in minutes (default: 7 days = 10080 minutes)
JWT_EXPIRE_MINUTES=10080

# ─── MongoDB (Required - Primary Database) ──────────────────
# MongoDB connection string (MongoDB Atlas or local instance)
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
# Or for local: mongodb://localhost:27017/soulsync_db
MONGODB_URL=mongodb://localhost:27017/soulsync_db
# Database name
MONGODB_DB=soulsync_db

# ─── Redis (Optional - For Caching) ─────────────────────────
# Redis connection URL (leave empty to disable caching)
# Redis improves response times by caching frequent queries
REDIS_URL=redis://localhost:6379
# Cache TTL (Time To Live) in seconds
REDIS_TTL_CHAT=600          # Chat response cache: 10 minutes
REDIS_TTL_SESSION=86400     # Session cache: 24 hours
REDIS_TTL_DEFAULT=300       # Default cache: 5 minutes

# ─── MySQL (DISABLED - Future Payments) ─────────────────────
# Uncomment and configure when implementing payment features
# Used for: Subscription management, billing, payments
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_DB=soulsync_finance
# MYSQL_USER=root
# MYSQL_PASSWORD=your_mysql_password_here

# ─── Feature Flags ──────────────────────────────────────────
# Enable/disable features (true/false)
ENABLE_PAYMENTS=false

# ─── Logging Configuration ──────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Log format: json, text
LOG_FORMAT=text

# ─── CORS Configuration ─────────────────────────────────────
# Comma-separated list of allowed origins (for production)
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# ─── Server Configuration ───────────────────────────────────
# Host and port for the backend server
HOST=0.0.0.0
PORT=8000

# ─── Rate Limiting (Optional) ───────────────────────────────
# Maximum requests per minute per user (0 = disabled)
RATE_LIMIT_PER_MINUTE=60

# ─── File Upload Configuration ──────────────────────────────
# Maximum file size for uploads (in bytes)
# MAX_UPLOAD_SIZE=10485760  # 10MB

# ─── External API Keys (Optional) ───────────────────────────
# Add these if you want to enable additional features

# OpenWeatherMap API (for weather-based suggestions)
# OPENWEATHER_API_KEY=your_openweather_api_key

# Google Maps API (for location-based features)
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ============================================================
# SETUP INSTRUCTIONS
# ============================================================
#
# 1. MONGODB SETUP:
#    - Go to https://www.mongodb.com/cloud/atlas
#    - Create a free cluster
#    - Get connection string from "Connect" → "Connect your application"
#    - Replace <password> with your database user password
#
# 2. GROQ API SETUP:
#    - Go to https://console.groq.com/keys
#    - Create a new API key
#    - Copy and paste it above
#
# 3. REDIS SETUP (Optional):
#    - Install Redis: https://redis.io/download
#    - Or use Docker: docker run -d -p 6379:6379 redis:latest
#    - Update REDIS_URL if using different host/port
#
# 4. RUN THE APPLICATION:
#    - Backend:  python -m uvicorn backend.main:app --reload
#    - Frontend: cd soulsync-frontend && npm run dev
#
# ============================================================